# Universal Configuration for Dummy Protocol - Testnet
# This is a sample configuration file for testing purposes

# AWS Configuration
AWS_ACCOUNT_ID="123456789012"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Blockchain Configuration
BLOCKCHAIN_PROTOCOL="dummy"
DEPLOYMENT_MODE="single-node"

# Instance Configuration
INSTANCE_TYPE="t3.medium"
CPU_TYPE="x86_64"

# Block Storage Configuration
DATA_VOLUMES_COUNT="1"

# Volume 1 - Primary Data
DATA_VOL_1_TYPE="gp3"
DATA_VOL_1_SIZE="100"
DATA_VOL_1_IOPS="3000"
DATA_VOL_1_THROUGHPUT="125"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_DEVICE_NAME="/dev/sdf"
DATA_VOL_1_FILESYSTEM="xfs"

# Volume 2 - Secondary Data
DATA_VOL_2_TYPE="gp3"
DATA_VOL_2_SIZE="100"
DATA_VOL_2_IOPS="3000"
DATA_VOL_2_THROUGHPUT="125"
DATA_VOL_2_MOUNT_PATH="/accounts"
DATA_VOL_2_DEVICE_NAME="/dev/sdg"

# Generic Protocol Configuration
BC_NETWORK="testnet"
CLIENT_CONFIG="dummy-1.0.0-rpc-base.sh"
CLIENT_VERSION="v1.0.0"

# Snapshot Configuration
SNAPSHOT_ENABLED="true"
SNAPSHOT_DOWNLOAD_URL="https://snapshots.dummy.org/testnet/latest.tar.gz"
# Snapshot Staging Volume (GiB). Set to a value > 0 to use a temporary gp3 EBS volume
# for snapshot download. Set to 0 or omit to download directly to /data (default).
SNAPSHOT_STAGING_VOL_SIZE="0"

# Traffic Shaping Configuration (optional - reduces outbound data transfer costs)
TRAFFIC_SHAPING_ENABLED="false"
TRAFFIC_SHAPING_RATE_MBIT="40"
TRAFFIC_SHAPING_CHECK_INTERVAL_SEC="60"
TRAFFIC_SHAPING_MAX_BLOCKS_BEHIND="10"

# Custom Protocol-Specific Variables (DUMMY prefix)
DUMMY_NODE_TYPE="validator"
DUMMY_SYNC_MODE="fast"
DUMMY_LOG_LEVEL="info"
