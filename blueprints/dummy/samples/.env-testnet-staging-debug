# Dummy - Snapshot Staging Cleanup DEBUG configuration
#
# Drives the snapshot staging lifecycle debug path (mount -> extract -> cleanup)
# using a small, cheap gp3 staging volume and a synthetic archive, so the
# staging_cleanup() fix can be validated end-to-end without a real multi-TB
# download. Deploy this to a TEST/SANDBOX account only.
#
# Expected result in cloud-init-output / node.log:
#   STAGING DEBUG: PASS                      (volume was created and deleted)
# A failure prints:
#   STAGING DEBUG: FAIL (orphaned volume vol-...)

# AWS Configuration
AWS_ACCOUNT_ID="123456789012"
AWS_REGION="us-east-1"

# Blockchain Configuration
BLOCKCHAIN_PROTOCOL="dummy"
DEPLOYMENT_MODE="single-node"

# Instance Configuration
INSTANCE_TYPE="t3.medium"
CPU_TYPE="x86_64"

# Generic Protocol Configuration
BC_NETWORK="testnet"
CLIENT_CONFIG="dummy-1.0.0-rpc-base.sh"
CLIENT_VERSION="v1.0.0"

# Snapshot Configuration
# SNAPSHOT_ENABLED=true + SNAPSHOT_STAGING_VOL_SIZE>0 triggers the staging debug path.
SNAPSHOT_ENABLED="true"
# Small staging volume so create/attach/delete is fast and cheap.
SNAPSHOT_STAGING_VOL_SIZE="10"

# Block Storage Configuration
DATA_VOLUMES_COUNT="1"

# Volume 1 - Primary Data
DATA_VOL_1_TYPE="gp3"
DATA_VOL_1_SIZE="100"
DATA_VOL_1_IOPS="3000"
DATA_VOL_1_THROUGHPUT="125"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_DEVICE_NAME="/dev/sdf"

# Custom Protocol-Specific Variables
DUMMY_NODE_TYPE="rpc"
DUMMY_SYNC_MODE="full"
DUMMY_LOG_LEVEL="info"
