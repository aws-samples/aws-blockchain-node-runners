##############################################################
# Ethereum Mainnet - Geth + Lighthouse (Full Node)
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="ethereum"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="mainnet"
CLIENT_CONFIG="geth-1.17.4-lighthouse-8.2.0-full.yml"

# Instance Configuration
INSTANCE_TYPE="r7g.2xlarge"
CPU_TYPE="ARM_64"

# Storage Configuration
# Geth full node requires ~2TB, adding buffer for growth
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="gp3"
DATA_VOL_1_SIZE="2560"
DATA_VOL_1_IOPS="8000"
DATA_VOL_1_THROUGHPUT="700"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_DEVICE_NAME="/dev/xvdg"
DATA_VOL_1_FILESYSTEM="ext4"

# Snapshot Configuration (optional)
SNAPSHOT_ENABLED="false"
# SNAPSHOT_DOWNLOAD_URL="https://snapshots.ethereum.org/mainnet/latest.tar.lz4"

# Ethereum Custom Configuration
# More checkpoint sync options: https://eth-clients.github.io/checkpoint-sync-endpoints/
ETH_CONSENSUS_CHECKPOINT_SYNC_URL="https://beaconstate.info"

# Supernode mode (Lighthouse only) - stores all 128 data columns for full blob serving.
# Required post-Pectra (May 2025) for blob_sidecars API and L2 rollup derivation.
# Options: "true" (supernode, 128 columns), "semi" (semi-supernode, 64 columns), "false" (regular, 4 columns)
ETH_CONSENSUS_SUPERNODE="true"
