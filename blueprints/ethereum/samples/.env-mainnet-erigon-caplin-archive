##############################################################
# Ethereum Mainnet - Erigon with Caplin (Archive Node)
# Caplin is Erigon's built-in consensus client
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="ethereum"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="mainnet"
CLIENT_CONFIG="erigon-3.4.3-caplin-archive.yml"

# Instance Configuration - HIGH PERFORMANCE
# Graviton4 with NVMe instance store for maximum I/O
INSTANCE_TYPE="i8g.4xlarge"
CPU_TYPE="ARM_64"

# Storage Configuration - INSTANCE STORE (NVMe SSD)
# <1ms latency, 250K+ IOPS, ephemeral storage
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="3750"              # 3.75TB NVMe instance store
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# Snapshot Configuration (optional)
SNAPSHOT_ENABLED="false"

# Ethereum Custom Configuration
# Caplin uses checkpoint sync for fast consensus layer sync
ETH_CONSENSUS_CHECKPOINT_SYNC_URL="https://beaconstate.info"
