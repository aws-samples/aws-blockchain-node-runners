##############################################################
# Bitcoin Core Mainnet - Full Node (HA)
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="bitcoin"
DEPLOYMENT_MODE="ha-nodes"
BC_NETWORK="mainnet"
CLIENT_CONFIG="bitcoin-core-v31.0-full.yml"

# Instance Configuration
INSTANCE_TYPE="r7i.2xlarge"
CPU_TYPE="x86_64"

# Storage Configuration
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="gp3"
DATA_VOL_1_SIZE="1500"
DATA_VOL_1_IOPS="6000"
DATA_VOL_1_THROUGHPUT="400"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_DEVICE_NAME="/dev/xvdg"
DATA_VOL_1_FILESYSTEM="ext4"

# HA Configuration
HA_NUMBER_OF_NODES="2"
HA_ALB_HEALTHCHECK_PORT="8332"
HA_ALB_HEALTHCHECK_HTTP_CODES="405"

# ALB Exposure (security)
# By default the load balancer is INTERNAL (reachable only inside the VPC) and
# ingress is restricted to the VPC CIDR. To expose the RPC endpoint beyond the
# VPC, uncomment and set the following:
# HA_ALB_INTERNET_FACING="true"          # expose the ALB to the internet (use with caution)
# HA_ALB_ALLOWED_CIDR="203.0.113.0/24"   # REQUIRED when internet-facing: restrict to trusted source IPs
# HA_ALB_CERTIFICATE_ARN="arn:aws:acm:REGION:ACCOUNT:certificate/ID"  # enable HTTPS (TLS terminated at the ALB)
