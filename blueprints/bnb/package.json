{
  "name": "aws-bnr-blueprint-bnb",
  "version": "2.0.0",
  "description": "BNB Smart Chain (BSC) blockchain node runner using the BSC Geth client",
  "engines": {
    "aws-blockchain-node-runners": ">=2.0.0"
  },
  "aws-blockchain-node-runner": {
    "BLOCKCHAIN_PROTOCOL": "bnb",
    "supportedDeploymentModes": [
      "single-node",
      "ha-nodes"
    ],
    "defaultConfiguration": "bsc-geth-v1.7.3-full.sh",
    "availableConfigurations": [
      {
        "name": "bsc-geth-v1.7.3-full.sh"
      },
      {
        "name": "bsc-reth-v0.1.1-full.sh"
      }
    ],
    "BC_NETWORKS": [
      "mainnet",
      "chapel"
    ],
    "defaultInstanceTypes": {
      "x86_64": "r7i.4xlarge",
      "ARM_64": "r8g.4xlarge"
    },
    "requiredPorts": [
      {
        "port": 8545,
        "protocol": "tcp",
        "description": "JSON RPC",
        "public": false
      },
      {
        "port": 8546,
        "protocol": "tcp",
        "description": "WebSocket",
        "public": false
      },
      {
        "port": 30303,
        "protocol": "tcp",
        "description": "P2P",
        "public": true
      },
      {
        "port": 30303,
        "protocol": "udp",
        "description": "P2P UDP",
        "public": true
      }
    ],
    "monitoring": {
      "healthCheckPath": "/",
      "metricsPort": 8545,
      "clientNames": ["BSC Geth"]
    },
    "storage": {
      "defaultDataVolumes": [
        {
          "name": "data",
          "sizeGiB": 4000,
          "type": "gp3",
          "iops": 10000,
          "throughput": 700,
          "mountPath": "/data",
          "fileSystem": "ext4"
        }
      ]
    },
    "snapshot": {
      "enabled": true,
      "downloadUrl": "https://raw.githubusercontent.com/48Club/bsc-snapshots/main/data.json"
    },
    "customEnvVarsNamePrefix": "BNB",
    "customEnvVars": [
      "BNB_DOWNLOAD_SNAPSHOT=true"
    ]
  }
}
