##############################################################
# BNB Smart Chain Mainnet - BSC Geth (Full Node, HA)
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="bnb"
DEPLOYMENT_MODE="ha-nodes"
BC_NETWORK="mainnet"
CLIENT_CONFIG="bsc-geth-v1.7.3-full.sh"

# Instance Configuration
INSTANCE_TYPE="i8g.4xlarge"
CPU_TYPE="ARM_64"

# Storage Configuration - instance store (single NVMe, no RAID)
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="3750"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# HA Configuration
HA_NUMBER_OF_NODES="2"
# Snapshot download (~30 min) + extraction (~45 min) + DB open (~30 min)
# means geth won't serve RPC for ~2 hours after launch
HA_ALB_HEALTHCHECK_GRACE_PERIOD_MIN="150"

# BNB Custom Configuration
BNB_DOWNLOAD_SNAPSHOT="true"
# Snapshot type: "local" = full node with complete state (MPT + snapshot, ~1 TiB), "none" = fast node with snapshot-only state (~365 GiB, needs extra sync)
BNB_SNAPSHOT_TYPE="local"

# Snapshot Staging Volume (GiB). Recommended for large snapshots when compressed archive
# + extracted data may exceed instance-store capacity. Set to 0 or omit to download directly to /data.
SNAPSHOT_STAGING_VOL_SIZE="500"

# ALB Exposure (security)
# By default the load balancer is INTERNAL (reachable only inside the VPC) and
# ingress is restricted to the VPC CIDR. To expose the RPC endpoint beyond the
# VPC, uncomment and set the following:
# HA_ALB_INTERNET_FACING="true"          # expose the ALB to the internet (use with caution)
# HA_ALB_ALLOWED_CIDR="203.0.113.0/24"   # REQUIRED when internet-facing: restrict to trusted source IPs
# HA_ALB_CERTIFICATE_ARN="arn:aws:acm:REGION:ACCOUNT:certificate/ID"  # enable HTTPS (TLS terminated at the ALB)
