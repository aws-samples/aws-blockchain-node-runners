##############################################################
# BNB Smart Chain Chapel Testnet - BSC Geth (Full Node)
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="bnb"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="chapel"
CLIENT_CONFIG="bsc-geth-v1.7.3-full.sh"

# Instance Configuration
INSTANCE_TYPE="i8g.4xlarge"
CPU_TYPE="ARM_64"

# Storage Configuration - instance store (single NVMe, no RAID)
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="3750"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# BNB Custom Configuration
BNB_DOWNLOAD_SNAPSHOT="false"
# Snapshot type: "local" = full node with complete state (MPT + snapshot, ~1 TiB), "none" = fast node with snapshot-only state (~365 GiB, needs extra sync)
# BNB_SNAPSHOT_TYPE="local"
