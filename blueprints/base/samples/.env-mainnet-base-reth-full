##############################################################
# Base Mainnet - base-reth-node + base-consensus (Full Node)
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="base"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="base-mainnet"
CLIENT_CONFIG="base-reth-v1.2.0-full.yml"

# Instance Configuration
# i8ge.6xlarge: 24 vCPU, 192 GB RAM, 2x 7500 GB NVMe (ARM)
INSTANCE_TYPE="i8ge.6xlarge"
CPU_TYPE="ARM_64"

# Storage Configuration - NVMe instance store (all drives combined into RAID 0)
DATA_VOLUMES_COUNT="1"
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# Snapshot Configuration
# Reth snapshots significantly reduce initial sync time (from days to hours)
# See https://docs.base.org/base-chain/node-operators/snapshots for details
SNAPSHOT_ENABLED="true"
SNAPSHOT_DOWNLOAD_URL="https://mainnet-reth-archive-snapshots.base.org"
# Staging volume size in GiB for snapshot download. Required because the compressed
# archive (~5 TB) + extracted data (~9-10 TB) exceeds i7i.12xlarge instance-store
# capacity (~10.5 TB). Set to 0 or omit to download directly to /data.
SNAPSHOT_STAGING_VOL_SIZE="5600"

# Traffic Shaping Configuration
# Recommended - Base has ~2s block time generating significant P2P traffic
TRAFFIC_SHAPING_ENABLED="true"
TRAFFIC_SHAPING_RATE_MBIT="40"
TRAFFIC_SHAPING_CHECK_INTERVAL_SEC="60"
TRAFFIC_SHAPING_MAX_BLOCKS_BEHIND="10"

# Base Custom Configuration
# L1 Ethereum RPC (required) - provide your own Ethereum mainnet endpoint
BASE_L1_RPC_URL="https://your-ethereum-l1-rpc-url"
# L1 Ethereum Beacon API (required) - provide your own Ethereum beacon endpoint
BASE_L1_BEACON_URL="https://your-ethereum-beacon-url"
