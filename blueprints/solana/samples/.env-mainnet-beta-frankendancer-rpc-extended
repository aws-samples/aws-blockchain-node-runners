##############################################################
# Solana Mainnet-Beta - Frankendancer RPC Extended Node
# Recommended for: dApps needing token/program/mint index lookups
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="solana"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="mainnet-beta"
CLIENT_CONFIG="frankendancer-0.1006.40100-rpc-extended.sh"

# Instance Configuration
# i7i.24xlarge: 96 vCPUs, 768 GB RAM (required for account indexing)
INSTANCE_TYPE="i7i.24xlarge"
CPU_TYPE="x86_64"

# Storage Configuration
# Using NVMe instance store for maximum I/O performance
# i7i.24xlarge has 6x 3,750 GB NVMe drives
# Data is ephemeral - lost on instance stop/termination
DATA_VOLUMES_COUNT="2"

# Volume 1 - Ledger/Data (NVMe instance store)
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="3750"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# Volume 2 - Accounts (NVMe instance store)
DATA_VOL_2_TYPE="instance-store"
DATA_VOL_2_SIZE="3750"
DATA_VOL_2_MOUNT_PATH="/accounts"
DATA_VOL_2_FILESYSTEM="ext4"

# Traffic Shaping Configuration
# Reduces outbound data transfer costs by up to 85%
TRAFFIC_SHAPING_ENABLED="true"
TRAFFIC_SHAPING_RATE_MBIT="20"
TRAFFIC_SHAPING_CHECK_INTERVAL_SEC="60"
TRAFFIC_SHAPING_MAX_BLOCKS_BEHIND="10"

# Solana Custom Configuration
SOLANA_NODE_IDENTITY_SECRET_ARN="none"
