##############################################################
# Solana Mainnet-Beta - Agave RPC Base Node (HA Deployment)
# Deployment: High Availability with Load Balancer
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="123456789012"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="solana"
DEPLOYMENT_MODE="ha-nodes"
BC_NETWORK="mainnet-beta"
CLIENT_CONFIG="agave-4.0.3-rpc-base.sh"

# Instance Configuration
INSTANCE_TYPE="i7i.12xlarge"
CPU_TYPE="x86_64"

# Storage Configuration
DATA_VOLUMES_COUNT="2"

# Volume 1 - Ledger/Data
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="2000"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# Volume 2 - Accounts
DATA_VOL_2_TYPE="instance-store"
DATA_VOL_2_SIZE="500"
DATA_VOL_2_MOUNT_PATH="/accounts"
DATA_VOL_2_FILESYSTEM="ext4"

# Traffic Shaping Configuration
TRAFFIC_SHAPING_ENABLED="true"
TRAFFIC_SHAPING_RATE_MBIT="40"
TRAFFIC_SHAPING_CHECK_INTERVAL_SEC="60"
TRAFFIC_SHAPING_MAX_BLOCKS_BEHIND="10"

# High Availability Configuration
HA_NUMBER_OF_NODES="2"
HA_ALB_HEALTHCHECK_PORT="8899"
HA_ALB_HEALTHCHECK_PATH="/health"
HA_ALB_HEALTHCHECK_GRACE_PERIOD_MIN="120"
HA_ALB_HEALTHCHECK_INTERVAL_SEC="30"
HA_ALB_HEALTHCHECK_TIMEOUT_SEC="10"
HA_ALB_HEALTHCHECK_HEALTHY_THRESHOLD="3"
HA_ALB_HEALTHCHECK_UNHEALTHY_THRESHOLD="2"
HA_NODES_HEARTBEAT_DELAY_MIN="120"
HA_ALB_DEREGISTRATION_DELAY_SEC="30"

# Solana Custom Configuration
SOLANA_NODE_IDENTITY_SECRET_ARN="none"

# ALB Exposure (security)
# By default the load balancer is INTERNAL (reachable only inside the VPC) and
# ingress is restricted to the VPC CIDR. To expose the RPC endpoint beyond the
# VPC, uncomment and set the following:
# HA_ALB_INTERNET_FACING="true"          # expose the ALB to the internet (use with caution)
# HA_ALB_ALLOWED_CIDR="203.0.113.0/24"   # REQUIRED when internet-facing: restrict to trusted source IPs
# HA_ALB_CERTIFICATE_ARN="arn:aws:acm:REGION:ACCOUNT:certificate/ID"  # enable HTTPS (TLS terminated at the ALB)
