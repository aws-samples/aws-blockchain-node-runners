##############################################################
# Solana Mainnet-Beta - Frankendancer RPC Base Node
# Recommended for: High-performance RPC nodes with traffic shaping
##############################################################

# AWS Configuration
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Availability Zone (optional - override automatic AZ selection for single-node deployments)
# AWS_AZ="us-east-1a"

# Stack Name Prefix (optional - deploy multiple stacks with same config on one account)
# STACK_NAME_PREFIX="DEV"

# Protocol Configuration
BLOCKCHAIN_PROTOCOL="solana"
DEPLOYMENT_MODE="single-node"
BC_NETWORK="mainnet-beta"
CLIENT_CONFIG="frankendancer-0.912.40003-rpc-base.sh"

# Instance Configuration
# i7i.12xlarge: 48 vCPUs, 384 GB RAM, 2x 3.84 TB NVMe instance store
INSTANCE_TYPE="i7i.12xlarge"
CPU_TYPE="x86_64"

# Storage Configuration
# Solana requires high-performance storage for ledger and accounts
# Use instance-store for best performance, or io2 for persistent storage
DATA_VOLUMES_COUNT="2"

# Volume 1 - Ledger/Data (2 TB minimum for mainnet-beta)
DATA_VOL_1_TYPE="instance-store"
DATA_VOL_1_SIZE="2000"
DATA_VOL_1_MOUNT_PATH="/data"
DATA_VOL_1_FILESYSTEM="ext4"

# Volume 2 - Accounts (500 GB minimum)
DATA_VOL_2_TYPE="instance-store"
DATA_VOL_2_SIZE="500"
DATA_VOL_2_MOUNT_PATH="/accounts"
DATA_VOL_2_FILESYSTEM="ext4"

# Traffic Shaping Configuration
# Highly recommended for RPC nodes - reduces outbound data transfer costs by up to 85%
# Solana mainnet-beta generates ~100-200 TiB/month without shaping
# With 40 Mbit/s limit: ~0.4 TiB/month (significant cost reduction)
TRAFFIC_SHAPING_ENABLED="true"
TRAFFIC_SHAPING_RATE_MBIT="40"
TRAFFIC_SHAPING_CHECK_INTERVAL_SEC="60"
TRAFFIC_SHAPING_MAX_BLOCKS_BEHIND="10"

# Solana Custom Configuration
# Optional: ARN of AWS Secrets Manager secret containing node identity keypair
# Set to "none" to generate a new identity on first start
SOLANA_NODE_IDENTITY_SECRET_ARN="none"
