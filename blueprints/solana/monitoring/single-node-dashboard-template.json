{
    "widgets": [
        {
            "height": 5,
            "width": 6,
            "y": 0,
            "x": 0,
            "type": "metric",
            "properties": {
                "view": "timeSeries",
                "stat": "Average",
                "period": 300,
                "stacked": false,
                "yAxis": { "left": { "min": 0 } },
                "region": "${REGION}",
                "metrics": [
                    [ "AWS/EC2", "CPUUtilization", "InstanceId", "${INSTANCE_ID}", { "label": "${INSTANCE_ID}" } ]
                ],
                "title": "CPU Utilization (%)"
            }
        },
        {
            "height": 5,
            "width": 6,
            "y": 5,
            "x": 0,
            "type": "metric",
            "properties": {
                "view": "timeSeries",
                "stacked": false,
                "region": "${REGION}",
                "stat": "Average",
                "period": 300,
                "metrics": [
                    [ "CWAgent", "cpu_usage_iowait", "InstanceId", "${INSTANCE_ID}", { "label": "${INSTANCE_ID}" } ]
                ],
                "title": "CPU I/O Wait (%)"
            }
        },
        {
            "height": 5,
            "width": 6,
            "y": 10,
            "x": 0,
            "type": "metric",
            "properties": {
                "view": "timeSeries",
