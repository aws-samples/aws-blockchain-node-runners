                    [ "CWAgent", "mem_used_percent", "InstanceId", "${INSTANCE_ID}", { "label": "${INSTANCE_ID}" } ]
                ],
                "title": "Memory Used (%)"
            }
        },
        {
            "height": 5,
            "width": 6,
            "y": 0,
            "x": 6,
            "type": "metric",
            "properties": {
                "metrics": [
                    [ { "expression": "m1/PERIOD(m1)", "label": "Read", "id": "e1" } ],
                    [ "CWAgent", "diskio_reads", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m1", "visible": false, "stat": "Sum", "period": 60 } ],
                    [ { "expression": "m2/PERIOD(m2)", "label": "Write", "id": "e2" } ],
                    [ "CWAgent", "diskio_writes", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m2", "visible": false, "stat": "Sum", "period": 60 } ]
                ],
                "view": "timeSeries",
                "stacked": false,
                "region": "${REGION}",
                "stat": "Sum",
                "period": 60,
                "title": "${D1_DEVICE_ID} (${D1_MOUNT_PATH}) Read/Write (IO/sec)"
            }
        },
        {
            "height": 5,
            "width": 6,
            "y": 5,
            "x": 6,
            "type": "metric",
            "properties": {
                "view": "timeSeries",
                "stat": "Sum",
                "period": 60,
                "stacked": false,
                "yAxis": { "left": { "min": 0 } },
                "region": "${REGION}",
                "metrics": [
                    [ { "expression": "IF(m2 !=0, (m1 / m2), 0)", "label": "Read", "id": "e1" } ],
                    [ "CWAgent", "diskio_read_time", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m1", "visible": false, "stat": "Sum", "period": 60 } ],
                    [ "CWAgent", "diskio_reads", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m2", "visible": false, "stat": "Sum", "period": 60 } ],
                    [ { "expression": "IF(m4 !=0, (m3 / m4), 0)", "label": "Write", "id": "e2" } ],
                    [ "CWAgent", "diskio_write_time", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m3", "visible": false, "stat": "Sum", "period": 60 } ],
                    [ "CWAgent", "diskio_writes", "InstanceId", "${INSTANCE_ID}", "name", "${D1_DEVICE_ID}", { "id": "m4", "visible": false, "stat": "Sum", "period": 60 } ]
                ],
                "title": "${D1_DEVICE_ID} (${D1_MOUNT_PATH}) Read/Write Latency (ms/op)"
            }
        },
