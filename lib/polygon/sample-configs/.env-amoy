################################################################
# Example configuration for Polygon PoS node runner on AWS    #
# Network: Amoy Testnet (Erigon)                               #
################################################################

AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

# Polygon network
POLYGON_NETWORK="amoy"

# Erigon (single container replaces Heimdall+Bor)
POLYGON_ERIGON_IMAGE="0xpolygon/erigon:v3.4.0"
POLYGON_HEIMDALL_API_URL="https://heimdall-api-amoy.polygon.technology"

# Instance configuration (smaller for testnet)
POLYGON_INSTANCE_TYPE="m7g.xlarge"                          # Graviton3: 4 vCPU, 16 GB RAM
POLYGON_CPU_TYPE="ARM_64"

# Storage configuration (testnet is much smaller)
POLYGON_DATA_VOL_SIZE="1000"                                # 1 TB
POLYGON_DATA_VOL_TYPE="gp3"
POLYGON_DATA_VOL_IOPS="5000"
POLYGON_DATA_VOL_THROUGHPUT="250"

# HA RPC nodes configuration
POLYGON_RPC_INSTANCE_TYPE="m7g.xlarge"
POLYGON_RPC_CPU_TYPE="ARM_64"
POLYGON_RPC_DATA_VOL_SIZE="1000"
POLYGON_RPC_DATA_VOL_TYPE="gp3"
POLYGON_RPC_DATA_VOL_IOPS="5000"
POLYGON_RPC_DATA_VOL_THROUGHPUT="250"
POLYGON_RPC_NUMBER_OF_NODES="2"
POLYGON_RPC_ALB_HEALTHCHECK_GRACE_PERIOD_MIN="10"
POLYGON_RPC_HA_NODES_HEARTBEAT_DELAY_MIN="60"
