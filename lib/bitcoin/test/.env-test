#############################################################
# Test configuration for Bitcoin nodes runner app on AWS    #
#############################################################

## Set the AWS account id and region for your environment ##
AWS_ACCOUNT_ID="1234567890"
AWS_REGION="us-east-1"

## Bitcoin network configuration ##
BITCOIN_NETWORK="mainnet"

## Bitcoin Core version ##
BITCOIN_VERSION="28.0"

## Instance configuration ##
BITCOIN_INSTANCE_TYPE="m7g.large"
BITCOIN_CPU_TYPE="ARM_64"

## Data volume configuration ##
BITCOIN_DATA_VOL_TYPE="gp3"
BITCOIN_DATA_VOL_SIZE="700"
BITCOIN_DATA_VOL_IOPS="5000"
BITCOIN_DATA_VOL_THROUGHPUT="250"

## Bitcoin Core configuration ##
BITCOIN_TXINDEX="false"
BITCOIN_SERVER="true"
BITCOIN_LISTEN="true"
BITCOIN_DBCACHE="4096"
BITCOIN_MAXCONNECTIONS="125"
BITCOIN_RPCALLOWIP="10.0.0.0/8"
BITCOIN_RPCAUTH="none"
BITCOIN_PRUNE="0"
BITCOIN_MAXMEMPOOL="300"
BITCOIN_MEMPOOLEXPIRY="336"
BITCOIN_MAXORPHANTX="100"
BITCOIN_BLOCKSONLY="false"
BITCOIN_ASSUMEVALID="none"

## ZMQ configuration ##
BITCOIN_ZMQPUBRAWBLOCK="none"
BITCOIN_ZMQPUBRAWTX="none"
BITCOIN_ZMQPUBHASHBLOCK="none"
BITCOIN_ZMQPUBHASHTX="none"

## Snapshot configuration ##
BITCOIN_RESTORE_FROM_SNAPSHOT="false"
BITCOIN_SNAPSHOT_URL="none"

## HA nodes configuration ##
BITCOIN_HA_NUMBER_OF_NODES="2"
BITCOIN_HA_ALB_HEALTHCHECK_GRACE_PERIOD_MIN="10"
BITCOIN_HA_NODES_HEARTBEAT_DELAY_MIN="60"
