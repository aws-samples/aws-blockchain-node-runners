#############################################################
# Example configuration for Bitcoin nodes runner app on AWS #
# Mainnet Full Node                                         #
#############################################################

## Set the AWS account id and region for your environment ##
AWS_ACCOUNT_ID="xxxxxxxxxxx"
AWS_REGION="us-east-1"

## Bitcoin network configuration ##
BITCOIN_NETWORK="mainnet"                     # Options: "mainnet", "testnet", "signet", "regtest"

## Bitcoin Core version ##
BITCOIN_VERSION="28.0"                        # Check https://bitcoincore.org/en/releases/ for latest version

## Instance configuration ##
BITCOIN_INSTANCE_TYPE="m7g.large"             # Recommended: m7g.large (Graviton3) or m7i.large (x86)
BITCOIN_CPU_TYPE="ARM_64"                     # Options: "ARM_64", "x86_64"

## Data volume configuration ##
BITCOIN_DATA_VOL_TYPE="gp3"                   # Options: "gp3", "io1", "io2", "instance-store"
BITCOIN_DATA_VOL_SIZE="700"                   # Size in GiB - mainnet requires ~650GB+ for full node
BITCOIN_DATA_VOL_IOPS="5000"                  # IOPS for EBS volumes
BITCOIN_DATA_VOL_THROUGHPUT="250"             # Throughput in MB/s for gp3 volumes

## Bitcoin Core configuration ##
BITCOIN_TXINDEX="false"                       # Enable transaction index (requires more disk space)
BITCOIN_SERVER="true"                         # Enable RPC server
BITCOIN_LISTEN="true"                         # Accept incoming connections
BITCOIN_DBCACHE="4096"                        # Database cache size in MB (higher = faster sync)
BITCOIN_MAXCONNECTIONS="125"                  # Maximum peer connections
BITCOIN_RPCALLOWIP="10.0.0.0/8"              # IP range allowed to connect to RPC
BITCOIN_RPCAUTH="none"                        # RPC authentication (generate with rpcauth.py)
BITCOIN_PRUNE="0"                             # 0 = no pruning, >550 = prune to this many MB
BITCOIN_MAXMEMPOOL="300"                      # Maximum mempool size in MB
BITCOIN_MEMPOOLEXPIRY="336"                   # Mempool expiry in hours
BITCOIN_MAXORPHANTX="100"                     # Maximum orphan transactions
BITCOIN_BLOCKSONLY="false"                    # Only download blocks (no mempool)
BITCOIN_ASSUMEVALID="none"                    # Skip signature verification up to this block hash

## ZMQ configuration (for applications that need real-time notifications) ##
BITCOIN_ZMQPUBRAWBLOCK="none"                 # e.g., "tcp://0.0.0.0:28332"
BITCOIN_ZMQPUBRAWTX="none"                    # e.g., "tcp://0.0.0.0:28333"
BITCOIN_ZMQPUBHASHBLOCK="none"                # e.g., "tcp://0.0.0.0:28334"
BITCOIN_ZMQPUBHASHTX="none"                   # e.g., "tcp://0.0.0.0:28335"

## Snapshot configuration (optional - speeds up initial sync) ##
BITCOIN_RESTORE_FROM_SNAPSHOT="false"         # Set to "true" to restore from snapshot
BITCOIN_SNAPSHOT_URL="none"                   # HTTPS URL to snapshot tarball

## HA nodes configuration ##
BITCOIN_HA_NUMBER_OF_NODES="2"                # Number of nodes in HA setup
BITCOIN_HA_ALB_HEALTHCHECK_GRACE_PERIOD_MIN="10"
BITCOIN_HA_NODES_HEARTBEAT_DELAY_MIN="60"
